_ORTHO_COMMON = [
    "src/ortho/ortho_front.ads",
    "src/ortho/ortho_jit.ads",
]

# ===========================================================================
# Mcode backend library (monolithic: common + ortho/mcode)
# ===========================================================================

ada_library(
    name = "ghdl_mcode_lib",
    srcs = _COMMON_SRCS + glob(
        [
            "src/ortho/mcode/*.ads",
            "src/ortho/mcode/*.adb",
        ],
        exclude = [
            "src/ortho/mcode/coffdump.adb",
            "src/ortho/mcode/elfdump.adb",
            "src/ortho/mcode/ortho_code_main.adb",
            "src/ortho/mcode/ortho_mcode.private.ads",
        ],
    ) + _ORTHO_COMMON + _GENERATED_COMMON + [
        ":default_paths_mcode_ads",
        ":elf_arch_ads",
        ":ortho_flags_ads",
        ":version_mcode_ads",
    ],
    compile_data = _COMPILE_DATA,
    copts = ["-gnat12"],
    deps = [
        ":fst",
        ":grt_c",
        ":mcode_c",
    ],
)

# ===========================================================================
# LLVM backend library (monolithic: common + ortho/llvm6)
# ===========================================================================

ada_library(
    name = "ghdl_llvm_jit_lib",
    srcs = _COMMON_SRCS + glob(
        [
            "src/ortho/llvm6/*.ads",
            "src/ortho/llvm6/*.adb",
        ],
        exclude = [
            "src/ortho/llvm6/ortho_code_main.adb",
            "src/ortho/llvm6/ortho_llvm.private.ads",
        ],
    ) + _ORTHO_COMMON + _GENERATED_COMMON + [
        ":default_paths_llvm_ads",
        ":version_llvm_ads",
    ],
    compile_data = _COMPILE_DATA,
    copts = ["-gnat12"],
    deps = [
        ":fst",
        ":grt_c",
        ":llvm_cbindings",
    ],
)

# ===========================================================================
# Backend alias — selects the active backend library
# ===========================================================================

alias(
    name = "ghdl_lib",
    actual = select({
        ":use_llvm_jit": ":ghdl_llvm_jit_lib",
        ":use_mcode": ":ghdl_mcode_lib",
    }),
)

# ===========================================================================
# ghdl binary (JIT — works with both mcode and LLVM backends)
# ===========================================================================

ada_binary(
    name = "ghdl",
    srcs = ["src/ghdldrv/ghdl_jit.adb"],
    copts = ["-gnat12"],
    linkopts = select({
        "@platforms//os:linux": [
            "-ldl",
            "-lm",
            "-shared-libgcc",
        ],
        "@platforms//os:macos": [
            "-shared-libgcc",
        ],
    }) + select({
        ":use_llvm_jit": ["-lstdc++"],
        ":use_mcode": [],
    }),
    visibility = ["//visibility:public"],
    deps = [":ghdl_lib"],
)

ghdl_with_backend(
    name = "ghdl_mcode",
    actual = ":ghdl",
    backend = "mcode",
    visibility = ["//visibility:public"],
)

ghdl_with_backend(
    name = "ghdl_llvm_jit",
    actual = ":ghdl",
    backend = "llvm-jit",
    visibility = ["//visibility:public"],
)

# ===========================================================================
# libghdl shared library (for pyGHDL / LSP)
# ===========================================================================

ada_shared_library(
    name = "libghdl",
    srcs = glob([
        "src/vhdl/libghdl/*.ads",
        "src/vhdl/libghdl/*.adb",
    ]),
    copts = ["-gnat12"],
    deps = [":ghdl_lib"],
)

