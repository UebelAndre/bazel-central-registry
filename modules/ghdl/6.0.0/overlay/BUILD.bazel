write_file(
    name = "elf_arch_ads",
    out = "elf_arch.ads",
    content = [
        "with Elf_Arch64;",
        "package Elf_Arch renames Elf_Arch64;",
    ],
)

write_file(
    name = "ortho_flags_ads",
    out = "ortho_code-x86-flags.ads",
    content = select({
        "@platforms//os:macos": [
            "with Ortho_Code.X86.Flags_Macosx64;",
            "package Ortho_Code.X86.Flags renames Ortho_Code.X86.Flags_Macosx64;",
