# ===========================================================================
# Backend selection
#
# string_flag "backend" selects the ortho code generation backend:
#   mcode    (default) — custom x86 JIT code generator (x86-only)
#   llvm-jit — LLVM-based JIT via MCJIT (cross-architecture)
#
# Use the transition targets (ghdl_mcode, ghdl_llvm_jit) to build with
# a specific backend without passing flags on the command line.
# ===========================================================================

string_flag(
    name = "backend",
    build_setting_default = "mcode",
    values = [
        "llvm-jit",
        "mcode",
    ],
    visibility = ["//visibility:public"],
)

config_setting(
    name = "use_mcode",
    flag_values = {":backend": "mcode"},
)

config_setting(
    name = "use_llvm_jit",
    flag_values = {":backend": "llvm-jit"},
)

# ===========================================================================
# Generated Ada files (shared by both backends)
# ===========================================================================

expand_template(
    name = "version_mcode_ads",
    out = "mcode_gen/version.ads",
    substitutions = {
        "@DESC@": "mcode",
        "@HASH@": "unknown",
        "@REF@": "bazel",
        "@VER@": "6.0.0",
    },
    template = "src/version.in",
)

expand_template(
    name = "version_llvm_ads",
    out = "llvm_gen/version.ads",
    substitutions = {
        "@DESC@": "llvm",
        "@HASH@": "unknown",
        "@REF@": "bazel",
        "@VER@": "6.0.0",
    },
    template = "src/version.in",
)

expand_template(
    name = "default_paths_mcode_ads",
    out = "mcode_gen/default_paths.ads",
    substitutions = {
        "@COMPILER_DEBUG@": "",
        "@COMPILER_GCC@": "",
        "@COMPILER_LLVM@": "",
        "@COMPILER_MCODE@": "ghdl",
        "@EXEEXT@": "",
        "@INCDIR_SUFFIX@": "include",
        "@INSTALL_PREFIX@": "",
        "@LIBDIR_SUFFIX@": "lib",
        "@LIBGHDLDIR_SUFFIX@": "lib/ghdl",
        "@POST_PROCESSOR@": "",
        "@SOEXT@": ".so",
        "@backend_version@": "mcode",
        "@default_pic@": "false",
    },
    template = "default_paths.ads.in",
)

expand_template(
    name = "default_paths_llvm_ads",
    out = "llvm_gen/default_paths.ads",
    substitutions = {
        "@COMPILER_DEBUG@": "",
        "@COMPILER_GCC@": "",
        "@COMPILER_LLVM@": "ghdl",
        "@COMPILER_MCODE@": "",
        "@EXEEXT@": "",
        "@INCDIR_SUFFIX@": "include",
        "@INSTALL_PREFIX@": "",
        "@LIBDIR_SUFFIX@": "lib",
        "@LIBGHDLDIR_SUFFIX@": "lib/ghdl",
        "@POST_PROCESSOR@": "",
        "@SOEXT@": ".so",
        "@backend_version@": "llvm",
        "@default_pic@": "false",
    },
    template = "default_paths.ads.in",
)

write_file(
    name = "ghdlsynth_maybe_ads",
    out = "ghdlsynth_maybe.ads",
    content = [
        "with Ghdlsynth;",
        "package Ghdlsynth_Maybe renames Ghdlsynth;",
    ],
)

write_file(
    name = "grt_readline_ads",
    out = "grt-readline.ads",
    content = [
        "with Grt.Readline_None;",
        "package Grt.Readline renames Grt.Readline_None;",
    ],
)

write_file(
    name = "grt_backtraces_impl_ads",
    out = "grt-backtraces-impl.ads",
    content = [
        "with Grt.Backtraces.Jit;",
        "package Grt.Backtraces.Impl renames Grt.Backtraces.Jit;",
    ],
)

_GENERATED_COMMON = [
    ":ghdlsynth_maybe_ads",
    ":grt_backtraces_impl_ads",
    ":grt_readline_ads",
]

# ===========================================================================
# Generated Ada files (mcode backend only)
