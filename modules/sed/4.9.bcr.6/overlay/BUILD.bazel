# Curated subset of gnulib utility headers that sed bundles and that we
# consider safe to expose as a public API.  "Safe" means the header parses
# correctly without our gnulib lib/stdio.h / lib/stdlib.h / etc. shadowing
# the system headers, AND without requiring our private config.h -- i.e. it
# only pulls in standard system headers or other listed-here gnulib headers.
#
# Headers explicitly excluded:
#   * lib/xalloc.h, lib/ialloc.h, lib/c-ctype.h -- they `#error "Please
#     include config.h first."` because they emit `_GL_INLINE` static-inline
#     functions, and config.h is intentionally not part of the public surface.
#   * lib/error.h, lib/version-etc.h, lib/binary-io.h -- they need
#     `_GL_ATTRIBUTE_FORMAT_*` macros that come from our lib/stdio.h
#     replacement (which we keep out of consumers' include paths).
#   * lib/gettext.h -- pulls <libintl.h>; sed itself doesn't link libintl.
#
# Exposed under the "sed/" prefix (via include_prefix) so consumers write
# `#include "sed/regex.h"` -- unambiguous and won't shadow system <regex.h>.
PUBLIC_HDRS = [
    # Header-only macro utilities.
    "lib/attribute.h",
    "lib/intprops.h",
    "lib/intprops-internal.h",
    "lib/ignore-value.h",
    "lib/verify.h",
    "lib/xalloc-oversized.h",

    # Indexed-size type used by dfa/quotearg.
    "lib/idx.h",

    # Pattern matching: POSIX regex + sed's fast DFA matcher.
    "lib/regex.h",
    "lib/dfa.h",

    # Obstack: extensible object stacks (header declares the API; objstack
    # functions come from libsed itself).
    "lib/obstack.h",

    # String quoting helpers.
    "lib/quote.h",
    "lib/quotearg.h",

    # Filename manipulation.
    "lib/dirname.h",
    "lib/filename.h",
    "lib/basename-lgpl.h",

    # Locale / charset queries.
    "lib/localcharset.h",
    "lib/hard-locale.h",
    "lib/setlocale_null.h",

    # Standalone misc.
    "lib/closeout.h",
    "lib/close-stream.h",
    "lib/exitfail.h",
    "lib/getprogname.h",
    "lib/progname.h",
]

cc_library(
    name = "lib/sed",
    srcs = LIB_SRCS,
    hdrs = PUBLIC_HDRS,
    copts = COPTS,
    # `lib_hdrs` is `implementation_deps` so the gnulib lib/*.h replacements
    # (which shadow <stdio.h>, <string.h>, etc.) don't leak to consumers of
    # `:libsed`.  See https://github.com/bazelbuild/bazel-central-registry/issues/7642
    # for the bug class this avoids -- under stricter compilers like
    # clang-21 a transitive lib/stdio.h on the include path can mis-order
    # against system headers and break unrelated gnulib macros.
    implementation_deps = [":lib_hdrs"],
    include_prefix = "sed",
    local_defines = LOCAL_DEFINES,
    strip_include_prefix = "lib",
    visibility = ["//visibility:public"],
)

alias(
    name = "libsed",
    actual = ":lib/sed",
    visibility = ["//visibility:public"],
)

# =============================================================================
# sed binary
# =============================================================================

write_file(
    name = "version_h",
    out = "sed/version.h",
    content = [
        "extern char const *Version;",
        "",
    ],
    newline = "unix",
)

write_file(
    name = "version_c",
    out = "sed/version.c",
    content = [
        "#include \"config.h\"",
        "char const *Version = \"{}\";".format(VERSION),
        "",
    ],
    newline = "unix",
)

cc_binary(
    name = "bin/sed",
    srcs = [
        "basicdefs.h",
        "sed/compile.c",
        "sed/debug.c",
        "sed/execute.c",
        "sed/mbcs.c",
        "sed/regexp.c",
        "sed/sed.c",
        "sed/sed.h",
        "sed/utils.c",
        "sed/utils.h",
        "sed/version.c",
        "sed/version.h",
    ],
    copts = COPTS,
    includes = [
        ".",
        "sed",
    ],
    local_defines = LOCAL_DEFINES + [
        # sed.c uses these directly via bindtextdomain().  AC_INIT exports
        # PACKAGE, and configure normally sets LOCALEDIR from --datarootdir.
        "PACKAGE=\\\"sed\\\"",
        "LOCALEDIR=\\\"/usr/share/locale\\\"",
    ],
    visibility = ["//visibility:public"],
    # sed_bin needs lib_hdrs directly: sed/utils.h uses macros like
    # _GL_ATTRIBUTE_FORMAT_PRINTF_STANDARD that come from lib/stdio.h.
    # libsed marks lib_hdrs as implementation_deps so consumers don't inherit
    # those headers transitively -- we re-list them here for the binary that
    # genuinely needs them.
    deps = [
        ":lib_hdrs",
        ":libsed",
    ],
)

# Legacy alias
alias(
    name = "sed_bin",
    actual = ":bin/sed",
    visibility = ["//visibility:public"],
)

alias(
    name = "sed",
    actual = ":bin/sed",
    visibility = ["//visibility:public"],
)

# =============================================================================
# Smoke test
# =============================================================================

write_file(
    name = "sed_test_input",
    out = "sed_test_input.txt",
    content = [
        "Hello World",
        "This is a test.",
        "Hello again.",
        "",
    ],
    newline = "unix",
)

genrule(
    name = "sed_test_output",
    srcs = ["sed_test_input.txt"],
    outs = ["sed_test_output.txt"],
    cmd = "$(execpath :sed) 's/Hello/Hallo/g' $(execpath :sed_test_input.txt) > $@",
    cmd_bat = "$(execpath :sed) \"s/Hello/Hallo/g\" $(execpath :sed_test_input.txt) > $@",
    tools = [":sed"],
)

write_file(
    name = "sed_test_golden",
    out = "sed_test_golden.txt",
    content = [
        "Hallo World",
        "This is a test.",
        "Hallo again.",
        "",
    ],
    newline = "unix",
)

diff_test(
    name = "sed_diff_test",
    file1 = "sed_test_output.txt",
    file2 = "sed_test_golden.txt",
)

# =============================================================================
# Additional native sed behavior tests
# =============================================================================
#
# The upstream testsuite/*.sh tests rely on the gnulib init.sh framework,
# `path_prepend_ ./sed`, and an executable bit on the .sh files that the
# tarball-overlay flow doesn't preserve.  Rather than carry a fragile runner,
# each `behavior_*` pair below runs one sed expression against a fixture and
# compares the output to a checked-in golden.
#
# The fixture is the "Summum Bonum" poem by Robert Browning, inlined here
# byte-for-byte from testsuite/distrib.inp lines 13-28 of the upstream
# tarball.  Inlining keeps the input fully hermetic (no host tool needed to
# slice it out) and so the tests can run on a host that doesn't yet have a
# working sed -- which is precisely the situation we're building sed for.
write_file(
    name = "browning_input",
    out = "browning.txt",
    content = [
        "                _Summum Bonum_",
        "",
        "    All the breath and the bloom of the",
        "            year in the bag of one bee:",
        "    All the wonder and wealth of the mine in",
        "         the heart of one gem:",
        "    In the core of one pearl all the shade and the",
        "           shine of the sea:",
        "    Breath and bloom, shade and shine, -- wonder,",
        "        wealth, and -- how far above them --",
        "          Truth, thats brighter than gem,",
        "          Trust, that's purer than pearl, --",
        "    Brightest truth, purest trust in the universe --",
        "              all were for me",
        "                 In the kiss of one girl.",
        "        -- Robert Browning",
        "",
    ],
    newline = "unix",
)

SED_BEHAVIOR_TESTS = {
    # Delete blank lines.
    "delete_blanks": {
        "expr": "/^$$/d",
        "golden": [
            "                _Summum Bonum_",
            "    All the breath and the bloom of the",
            "            year in the bag of one bee:",
            "    All the wonder and wealth of the mine in",
            "         the heart of one gem:",
            "    In the core of one pearl all the shade and the",
            "           shine of the sea:",
            "    Breath and bloom, shade and shine, -- wonder,",
            "        wealth, and -- how far above them --",
            "          Truth, thats brighter than gem,",
            "          Trust, that's purer than pearl, --",
            "    Brightest truth, purest trust in the universe --",
            "              all were for me",
            "                 In the kiss of one girl.",
            "        -- Robert Browning",
            "",
        ],
    },
    # Extended regex via -E with alternation.
    "extended_regex": {
        "expr": "s/(pearl|gem|sea)/JEWEL/g",
        "extra_flags": "-E",
        "golden": [
            "                _Summum Bonum_",
            "",
            "    All the breath and the bloom of the",
            "            year in the bag of one bee:",
            "    All the wonder and wealth of the mine in",
            "         the heart of one JEWEL:",
            "    In the core of one JEWEL all the shade and the",
            "           shine of the JEWEL:",
            "    Breath and bloom, shade and shine, -- wonder,",
            "        wealth, and -- how far above them --",
            "          Truth, thats brighter than JEWEL,",
            "          Trust, that's purer than JEWEL, --",
            "    Brightest truth, purest trust in the universe --",
            "              all were for me",
            "                 In the kiss of one girl.",
            "        -- Robert Browning",
            "",
        ],
    },
    # `-n` plus explicit `p`: print only lines mentioning the speaker.
    "print_match": {
        "expr": "/Browning/p",
        "extra_flags": "-n",
        "golden": [
            "        -- Robert Browning",
            "",
        ],
    },
    # Address range with grouped commands - strip leading whitespace from
    # the first three content lines after the title.
    "range_trim": {
        "expr": "3,5s/^ *//",
        "golden": [
            "                _Summum Bonum_",
            "",
            "All the breath and the bloom of the",
            "year in the bag of one bee:",
            "All the wonder and wealth of the mine in",
            "         the heart of one gem:",
            "    In the core of one pearl all the shade and the",
            "           shine of the sea:",
            "    Breath and bloom, shade and shine, -- wonder,",
            "        wealth, and -- how far above them --",
            "          Truth, thats brighter than gem,",
            "          Trust, that's purer than pearl, --",
            "    Brightest truth, purest trust in the universe --",
            "              all were for me",
            "                 In the kiss of one girl.",
            "        -- Robert Browning",
            "",
        ],
    },
    # Hold-space swap: reverse line order ("tac" emulation).
    # Both `$` chars are doubled so genrule's cmd template leaves them alone.
    # No `-n`: the classic idiom relies on auto-print for the final line.
    "reverse_lines": {
        "expr": "1!G;h;$$!d",
        "golden": [
            "        -- Robert Browning",
            "                 In the kiss of one girl.",
            "              all were for me",
            "    Brightest truth, purest trust in the universe --",
            "          Trust, that's purer than pearl, --",
            "          Truth, thats brighter than gem,",
            "        wealth, and -- how far above them --",
            "    Breath and bloom, shade and shine, -- wonder,",
            "           shine of the sea:",
            "    In the core of one pearl all the shade and the",
            "         the heart of one gem:",
            "    All the wonder and wealth of the mine in",
            "            year in the bag of one bee:",
            "    All the breath and the bloom of the",
            "",
            "                _Summum Bonum_",
            "",
        ],
    },
    # Basic substitution: rewrite the title marker.
    "substitution": {
        "expr": "s/_Summum Bonum_/== Summum Bonum ==/",
        "golden": [
            "                == Summum Bonum ==",
            "",
            "    All the breath and the bloom of the",
            "            year in the bag of one bee:",
            "    All the wonder and wealth of the mine in",
            "         the heart of one gem:",
            "    In the core of one pearl all the shade and the",
            "           shine of the sea:",
            "    Breath and bloom, shade and shine, -- wonder,",
            "        wealth, and -- how far above them --",
            "          Truth, thats brighter than gem,",
            "          Trust, that's purer than pearl, --",
            "    Brightest truth, purest trust in the universe --",
            "              all were for me",
            "                 In the kiss of one girl.",
            "        -- Robert Browning",
            "",
        ],
    },
}

[
    [
        write_file(
            name = "behavior_{}_golden".format(name),
            out = "behavior_{}_golden.txt".format(name),
            content = spec["golden"],
            newline = "unix",
        ),
        genrule(
            name = "behavior_{}_output".format(name),
            srcs = [":browning_input"],
            outs = ["behavior_{}_output.txt".format(name)],
            cmd = "$(execpath :sed) {extra} '{expr}' $(SRCS) > $@".format(
                expr = spec["expr"],
                extra = spec.get("extra_flags", ""),
            ),
            tools = [":sed"],
        ),
        diff_test(
            name = "behavior_{}_test".format(name),
            file1 = "behavior_{}_output.txt".format(name),
            file2 = "behavior_{}_golden.txt".format(name),
        ),
    ]
    for name, spec in SED_BEHAVIOR_TESTS.items()
]
