VERSION = "4.9"

# =============================================================================
# User-configurable feature flags
# =============================================================================

# --disable-i18n (configure.ac line ~143): when disabled, ac_cv_func_wcscoll is
# forced to no, which causes sed to skip the wide-character collation paths
# used for internationalized regex matching.
bool_flag(
    name = "enable_i18n",
    build_setting_default = True,
    visibility = ["//visibility:public"],
)

# gl_DISABLE_THREADS (configure.ac line ~33): sed's stock configure unconditionally
# disables gnulib's threadlib. Exposing this lets users opt into thread support if
# their environment provides it.
bool_flag(
    name = "enable_threads",
    build_setting_default = True,
    visibility = ["//visibility:public"],
)

config_setting(
    name = "i18n_enabled",
    flag_values = {":enable_i18n": "True"},
)

config_setting(
    name = "i18n_disabled",
    flag_values = {":enable_i18n": "False"},
)

config_setting(
    name = "threads_enabled",
    flag_values = {":enable_threads": "True"},
)

config_setting(
    name = "threads_disabled",
    flag_values = {":enable_threads": "False"},
)

# =============================================================================
# Package information (mirrors AC_INIT in configure.ac)
# =============================================================================

package_info(
    name = "sed_package_info",
    package_name = "GNU sed",
    aliases = {
        "VERSION": "PACKAGE_VERSION",
    },
    module_bazel = "MODULE.bazel",
    package_bugreport = "bug-sed@gnu.org",
    package_url = "https://www.gnu.org/software/sed/",
    strip_bcr_version = True,
)

# =============================================================================
