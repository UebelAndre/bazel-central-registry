# =============================================================================

SED_UNIQUE_M4_FILES = [
    "m4/gnulib-comp.m4",
    "m4/wchar_t.m4",
    "m4/year2038.m4",
]

# Map each prebuilt rules_cc_autoconf gnulib m4 file directly. The mapping
# strips the `m4/` prefix and `.m4` suffix to derive the dep label.
GNULIB_M4_DEPS = [
    "@rules_cc_autoconf//gnulib/m4/{}".format(file[len("m4/"):-len(".m4")])
    for file in glob(
        include = ["m4/*.m4"],
        exclude = SED_UNIQUE_M4_FILES,
    )
]

# m4/wchar_t.m4 - simple compile-time check for wchar_t type.
autoconf(
    name = "m4_wchar_t",
    checks = [
        checks.AC_TRY_COMPILE(
            name = "gt_cv_c_wchar_t",
            code = "#include <stddef.h>\nwchar_t foo = (wchar_t)'\\0';\nint main(void) { return 0; }\n",
        ),
        checks.AC_DEFINE(
            "HAVE_WCHAR_T",
            1,
            requires = ["gt_cv_c_wchar_t"],
        ),
    ],
)

# m4/year2038.m4 - guarantees 64-bit time_t; on mingw we set the compat define.
# Other platforms simply assume modern 64-bit time_t.
autoconf(
    name = "m4_year2038",
    checks = select({
        "@platforms//os:windows": [
            checks.AC_DEFINE("__MINGW_USE_VC2005_COMPAT", 1),
        ],
        "//conditions:default": [],
    }),
)

