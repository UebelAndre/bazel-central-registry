    "m4_{}".format(file[len("m4/"):-len(".m4")])
    for file in SED_UNIQUE_M4_FILES
]

# =============================================================================
# configure_ac - aggregate target replicating sed's configure.ac
# =============================================================================

autoconf(
    name = "configure_ac",
    checks = [
        # ---- sed-specific defines from configure.ac ----
        # AC_DEFINE([GNULIB_NO_VLA], [1])
        checks.AC_DEFINE("GNULIB_NO_VLA", 1),

        # gnulib uses GUARD_PREFIX as a prefix on its replacement-header include
        # guards (e.g. _GL_STDDEF_H).  The shell macros in gnulib-common.m4 set
        # this from PACKAGE_NAME; sed expects "GL".
        checks.AC_SUBST("GUARD_PREFIX", "GL"),

        # AC_CHECK_HEADERS_ONCE(locale.h errno.h wchar.h wctype.h mcheck.h)
        # (errno.h/wchar.h/wctype.h are also handled by the dedicated gnulib m4
        # modules but the AC_CHECK_HEADERS form additionally defines HAVE_*_H)
        checks.AC_CHECK_HEADER(
            "mcheck.h",
            define = "HAVE_MCHECK_H",
        ),

        # AC_CHECK_FUNCS_ONCE(...) - only the ones not already covered by the
        # per-function gnulib m4 modules in deps (isatty/memcpy/strtoul/readlink/
        # popen/setlocale/wcscoll are pulled in via @rules_cc_autoconf//gnulib/m4).
    ] + macros.AC_CHECK_FUNCS([
        "isascii",
        "strchr",
        "pathconf",
        "fchown",
        "fchmod",
    ]) + [

        # AC_CACHE_CHECK([whether "rt" can be used with fopen])
        # The original is a runtime check. Compile-only environments can't
        # safely assert this; default to "no" for portability, then enable
        # on cygwin/mingw via a select() below.
        checks.AC_DEFINE("LOCALEDIR", '"/usr/share/locale"'),
    ] + select({
        "@platforms//os:windows": [
            checks.AC_DEFINE("HAVE_FOPEN_RT", 1),
        ],
        "//conditions:default": [],
    }) + select({
        ":i18n_disabled": [
            # Mirrors `if test "x$enable_i18n" = xno; then ac_cv_func_wcscoll=no`
            checks.AC_SUBST("ac_cv_func_wcscoll", "no"),
        ],
        "//conditions:default": [],
    }),
    deps = [
        ":sed_package_info",
    ] + SED_UNIQUE_AUTOCONF_TARGETS + GNULIB_M4_DEPS,
)

# =============================================================================
# Generated config header (config.h.in -> config.h)
# =============================================================================

autoconf_hdr(
    name = "config_h",
    out = "config.h",
    template = "config_h.in",
    deps = [":configure_ac"],
)

# =============================================================================
# Generated gnulib headers (lib/*.in.h -> lib/*.h)
# =============================================================================

# Templates that need both @VAR@ substitution AND inline expansion of the
# gnulib helper headers (_GL_ARG_NONNULL, _GL_WARN_ON_USE, etc.)
# Each entry maps a generated header path to its template.  Headers whose
# upstream gnulib module only generates a replacement when the system version
# is incomplete (errno.h, assert.h) are intentionally omitted: on the supported
# targets the system header is fine and gnulib code includes it with <>.
GENERATED_HDRS = {
    "lib/alloca.h": "lib/alloca.in.h",
    "lib/ctype.h": "lib/ctype.in.h",
    "lib/fcntl.h": "lib/fcntl.in.h",
    "lib/inttypes.h": "lib/inttypes.in.h",
    "lib/langinfo.h": "lib/langinfo.in.h",
    "lib/limits.h": "lib/limits.in.h",
    "lib/locale.h": "lib/locale.in.h",
    "lib/selinux/context.h": "lib/se-context.in.h",
    "lib/selinux/label.h": "lib/se-label.in.h",
    "lib/selinux/selinux.h": "lib/se-selinux.in.h",
    "lib/stdalign.h": "lib/stdalign.in.h",
    "lib/stddef.h": "lib/stddef.in.h",
    "lib/stdint.h": "lib/stdint.in.h",
    "lib/stdio.h": "lib/stdio.in.h",
    "lib/stdlib.h": "lib/stdlib.in.h",
    "lib/string.h": "lib/string.in.h",
    "lib/sys/random.h": "lib/sys_random.in.h",
    "lib/sys/stat.h": "lib/sys_stat.in.h",
    "lib/sys/types.h": "lib/sys_types.in.h",
    "lib/time.h": "lib/time.in.h",
    "lib/unistd.h": "lib/unistd.in.h",
    "lib/wchar.h": "lib/wchar.in.h",
    "lib/wctype.h": "lib/wctype.in.h",
}

# Fallback substitutions for @VAR@ markers that gnulib leaves unset on the
# supported targets (typically because the upstream m4 module only sets them
# when the system header is incomplete). Each value is what the corresponding
# variable defaults to in gnulib's Makefile.am when its check did not fire.
DEFAULT_SUBSTITUTIONS = {
    "@HAVE_LANGINFO_T_FMT_AMPM@": "1",
    "@HAVE_LANGINFO_YESEXPR@": "1",
}

[
    autoconf_hdr(
        name = hdr[:-len(".h")].replace("/", "_") + "_h",
        out = hdr,
        defaults = True,
        inlines = {
            "/* The definition of _GL_ARG_NONNULL is copied here.  */": "lib/arg-nonnull.h",
            "/* The definition of _GL_WARN_ON_USE is copied here.  */": "lib/warn-on-use.h",
            "/* The definitions of _GL_FUNCDECL_RPL etc. are copied here.  */": "lib/c++defs.h",
        },
        mode = "subst",
        substitutions = DEFAULT_SUBSTITUTIONS,
        template = template,
        deps = [":configure_ac"],
    )
    for hdr, template in GENERATED_HDRS.items()
]

# lib/malloc/*.gl.h -- gnulib renames a few headers so they can be included
# with a fresh set of macros; the contents are unchanged so a plain file copy
# is enough.
[
    copy_file(
        name = name,
        src = src,
        out = out,
    )
    for name, src, out in [
        ("dynarray_skeleton_gl_h", "lib/malloc/dynarray-skeleton.c", "lib/malloc/dynarray-skeleton.gl.h"),
        ("dynarray_gl_h", "lib/malloc/dynarray.h", "lib/malloc/dynarray.gl.h"),
        ("scratch_buffer_gl_h", "lib/malloc/scratch_buffer.h", "lib/malloc/scratch_buffer.gl.h"),
    ]
]

# lib/static_assert.h - source file uses gnulib's _GL_VERIFY macros under the
# alternate name _GL_STATIC_ASSERT.  Generated via expand_template token rename.
expand_template(
    name = "static_assert_h",
    out = "lib/static_assert.h",
    substitutions = {
        "_GL_VERIFY": "_GL_STATIC_ASSERT",
        "_gl_verify": "_gl_static_assert",
    },
    template = "lib/verify.h",
)

# stdckdint.h is a C23 header that most systems don't ship.  The gnulib template
# has no @VAR@ markers, so we just copy it into lib/ verbatim.
copy_file(
    name = "stdckdint_h",
    src = "lib/stdckdint.in.h",
    out = "lib/stdckdint.h",
)

GENERATED_HDR_LABELS = [":{}".format(hdr[:-len(".h")].replace("/", "_") + "_h") for hdr in GENERATED_HDRS.keys()]

ALL_GENERATED_HDRS = [
    ":config_h",
    ":static_assert_h",
    ":stdckdint_h",
    ":dynarray_skeleton_gl_h",
    ":dynarray_gl_h",
    ":scratch_buffer_gl_h",
] + GENERATED_HDR_LABELS

# =============================================================================
# Library sources
# =============================================================================

COPTS = select({
    "@rules_cc//cc/compiler:msvc-cl": [
        "/w",
    ],
    "//conditions:default": [
        "-w",
        # Some gnulib sources (e.g. lib/localeinfo.c) use C11 `static_assert`
        # as a bare keyword via <assert.h>; require at least C11.
        "-std=gnu11",
    ],
})

LOCAL_DEFINES = [
    "HAVE_CONFIG_H",
    # gnulib's lib/localeinfo.c uses the bare keyword `static_assert` without
    # including <assert.h>.  config.h normally provides this define only when
    # HAVE_C_STATIC_ASSERT is unset, but the autoconf check correctly detects
    # C11 support on modern toolchains and leaves it set, so we surface the
    # mapping here unconditionally.
    "static_assert=_Static_assert",
]

# Headers shipped in the lib/ tree that gnulib code includes directly.
LIB_STATIC_HDRS = glob(
    include = ["lib/**/*.h"],
    exclude = ["lib/**/*.in.h"] + list(GENERATED_HDRS.keys()) + [
        "lib/static_assert.h",
        "lib/malloc/dynarray-skeleton.gl.h",
        "lib/malloc/dynarray.gl.h",
        "lib/malloc/scratch_buffer.gl.h",
    ],
)

cc_library(
    name = "lib_hdrs",
    hdrs = LIB_STATIC_HDRS + ALL_GENERATED_HDRS,
    includes = [
        ".",
        "lib",
    ],
    textual_hdrs = [
        "lib/regex_internal.c",
        "lib/regcomp.c",
        "lib/regexec.c",
        "lib/malloc/dynarray-skeleton.c",
