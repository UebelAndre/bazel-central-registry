    "ctangleboot.cin",
    "cwebboot.cin",
    "tangle.web",
    "tangle.ch",
    "cwebdir/ctangle.w",
    "cwebdir/ctang-w2c.ch",
    "cwebdir/common.w",
    "cwebdir/comm-w2c.ch",
    "cwebdir/comm-w2c.h",
    "cwebdir/iso_types.w",
])

# Re-export bootstrap tools for use in macros.
alias(
    name = "tangle",
    actual = "//texk/web2c/web2c:tangle",
    visibility = ["//visibility:public"],
)

alias(
    name = "ctangle",
    actual = "//texk/web2c/web2c:ctangle",
    visibility = ["//visibility:public"],
)

# =============================================================================
# Web2c config headers (w2c/config.h + w2c/c-auto.h)
# =============================================================================

autoconf_hdr(
    name = "w2c_c_auto_h",
    out = "w2c/c-auto.h",
    template = "c-auto.in",
    deps = ["//:configure"],
)

cc_library(
    name = "w2c_config",
    hdrs = [
        "cpascal.h",
        "help.h",
        "texmfmp-help.h",
        "w2c/config.h",
        ":w2c_c_auto_h",
    ],
    includes = ["."],
    visibility = ["//visibility:public"],
    deps = ["//texk/kpathsea"],
)

# =============================================================================
# Web2c support library (shared by all engines)
# =============================================================================

cc_library(
    name = "web2c_lib",
    srcs = [
        "lib/basechsuffix.c",
        "lib/chartostring.c",
        "lib/coredump.c",
        "lib/eofeoln.c",
        "lib/fprintreal.c",
        "lib/input2int.c",
        "lib/inputint.c",
        "lib/main.c",
        "lib/openclose.c",
        "lib/printversion.c",
        "lib/setupvar.c",
        "lib/uexit.c",
        "lib/usage.c",
        "lib/version.c",
        "lib/zround.c",
