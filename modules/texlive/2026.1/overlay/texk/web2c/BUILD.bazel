# =============================================================================
# Tests
# =============================================================================

[
    genrule(
        name = engine + "_version",
        outs = [engine + "_version.txt"],
        cmd = "$(execpath :{engine}) --version > $@".format(engine = engine),
        tools = [":" + engine],
    )
    for engine in [
        "luatex",
        "luahbtex",
        "hitex",
    ]
]

sh_test(
    name = "tangle_test",
    srcs = ["tangle.test"],
    data = [
        ":tangle",
        "//texk/kpathsea",
    ] + glob(["cftests/**"]),
    env = {
        "BinDir": "$(rootpath :tangle)/..",
        "srcdir": ".",
    },
    target_compatible_with = select({
        "@platforms//os:windows": ["@platforms//:incompatible"],
        "//conditions:default": [],
    }),
)
