# =============================================================================
# TeX engine (plain TeX)
# =============================================================================

# TODO(web2c): The TeX engines require a tangle→web2c→compile pipeline.
# The tangle step produces a .p file from .web + .ch, then web2c converts
# the Pascal to C, fixwrites cleans it up, and splitup splits large files.
# This is complex and depends on the bootstrap tools in web2c/.
#
# For now, we declare the targets but the full genrule pipeline for each
# engine needs the exact .web/.ch file mappings which vary per engine.
# The pattern for each WEB-based engine is:
#
#   genrule(tangle .web+.ch -> .p)
#   genrule(web2c+fixwrites+splitup .p -> .c files)
#   cc_binary(compile .c files)
#
# C-native engines (luatex, xetex, hitex) are simpler: just cc_binary
# with their source directories.

# =============================================================================
# pdftex - PDF-producing TeX engine
# =============================================================================

cc_library(
    name = "libpdftex",
    srcs = glob(
        ["pdftexdir/*.c"],
        exclude = ["pdftexdir/ttf2afm.c"],
    ),
    hdrs = glob(["pdftexdir/*.h"]),
    copts = TEXLIVE_COPTS,
    local_defines = TEXLIVE_LOCAL_DEFINES + ["pdfTeX"],
    deps = [
        ":md5",
        ":web2c_lib",
        "//texk/kpathsea",
        "@libpng//:png",
        "@xpdf",
        "@zlib",
    ],
)

# =============================================================================
# luatex - Lua-scriptable TeX engine
