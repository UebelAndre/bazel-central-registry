    local_defines = TEXLIVE_LOCAL_DEFINES,
    strip_include_prefix = "lib",
    visibility = ["//visibility:public"],
    deps = [
        ":w2c_config",
        "//texk/kpathsea",
        "@zlib",
    ],
)

# =============================================================================
