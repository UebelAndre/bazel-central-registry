# ======================================================================
# Generated headers
# ======================================================================

write_file(
    name = "autoconf_fixup_h",
    out = "include/generated/autoconf_fixup.h",
    content = [
        "/* Undefine configs whose depends-on is unsatisfied. */",
        "/* rules_kconfig emits all settings regardless of dependency. */",
        "#ifndef CONFIG_BOOT_RETRY",
        "#undef CONFIG_BOOT_RETRY_TIME",
        "#undef CONFIG_BOOT_RETRY_MIN",
        "#endif",
        "",
    ],
)

write_file(
    name = "version_h",
    out = "include/generated/version_autogenerated.h",
    content = [
        '#define PLAIN_VERSION "' + UBOOT_VERSION + '"',
        '#define U_BOOT_VERSION "U-Boot " PLAIN_VERSION',
        "#define U_BOOT_VERSION_NUM 2025",
        "#define U_BOOT_VERSION_NUM_PATCH 1",
        '#define CC_VERSION_STRING ""',
        '#define LD_VERSION_STRING ""',
        "",
    ],
)

generate_timestamp_h(
    name = "timestamp_h",
    out = "include/generated/timestamp_autogenerated.h",
)

write_file(
    name = "defaultenv_h",
    out = "include/generated/defaultenv_autogenerated.h",
    content = [
        "#define DEFAULT_ENV_INSTANCE_EMBEDDED",
        "#include <env_default.h>",
        "",
    ],
)

generate_config_h(
    name = "config_h",
    out = "include/config.h",
    board = "@u-boot_kconfig//:CONFIG_SYS_BOARD",
    config_name = "@u-boot_kconfig//:CONFIG_SYS_CONFIG_NAME",
    vendor = "@u-boot_kconfig//:CONFIG_SYS_VENDOR",
)

write_file(
    name = "config_data_gz_h",
    out = "include/generated/config_data_gz.h",
    content = [
        "static const char config_data_gz[] = {};",
        "static const unsigned long config_data_size = 0;",
        "",
    ],
)

generate_dt_h(
    name = "dt_h",
    device_tree = "@u-boot_kconfig//:CONFIG_DEFAULT_DEVICE_TREE",
    out = "include/generated/dt.h",
)

write_file(
    name = "environment_h",
    out = "include/generated/environment.h",
    content = [""],
)

write_file(
    name = "bmp_logo_data_h",
    out = "include/bmp_logo_data.h",
    content = [""],
)

# Copy kconfig-generated config.h to include/generated/autoconf.h.
# This file is board-specific — kconfig_autoconf reads transitioned
# flag values at build time and autoconf_hdr renders them into config.h.
copy_file(
    name = "autoconf_h",
    src = "@u-boot_kconfig//:config_h",
    out = "include/generated/autoconf.h",
)

# Minimal header target for asm-offsets (avoids circular dep with generated_headers)
cc_library(
    name = "kconfig_headers",
    hdrs = [":autoconf_h"],
    includes = ["include"],
    deps = ["@u-boot_kconfig//:config"],
)

_GENERATED_HDRS = [
    ":autoconf_h",
    "include/bmp_logo_data.h",
    "include/generated/autoconf_fixup.h",
    "include/config.h",
    "include/generated/config_data_gz.h",
    "include/generated/defaultenv_autogenerated.h",
    "include/generated/dt.h",
    "include/generated/environment.h",
    "include/generated/timestamp_autogenerated.h",
    "include/generated/version_autogenerated.h",
]

_ALL_HDRS = glob([
    "include/**/*.h",
    "scripts/dtc/libfdt/**/*.h",
    "lib/lzma/**/*.h",
]) + _GENERATED_HDRS

_ASM_OFFSETS_HDRS = _ALL_HDRS + glob([
    "arch/arm/include/**/*.h",
    "arch/sandbox/include/**/*.h",
    "arch/x86/include/**/*.h",
    "arch/riscv/include/**/*.h",
    "arch/mips/include/**/*.h",
    "arch/powerpc/include/**/*.h",
])

_ASM_OFFSETS_COPTS = [
    "-include",
    "include/linux/kconfig.h",
    "-D__KERNEL__",
    "-D__UBOOT__",
    "-DDO_DEPS_ONLY",
    "-ffreestanding",
    "-fno-builtin",
    "-Os",
]

uboot_asm_offsets(
    name = "gen_generic_asm_offsets",
    src = "lib/asm-offsets.c",
    out = "include/generated/generic-asm-offsets.h",
    hdrs = _ASM_OFFSETS_HDRS,
    copts = _ASM_OFFSETS_COPTS,
    includes = [
        ".",
        "include",
    ] + select({
        ":arch_arm": ["arch/arm/include"],
        ":arch_sandbox": ["arch/sandbox/include"],
        ":arch_x86": ["arch/x86/include"],
        ":arch_riscv": ["arch/riscv/include"],
        ":arch_mips": ["arch/mips/include"],
        ":arch_powerpc": ["arch/powerpc/include"],
        "//conditions:default": [],
    }),
    deps = [":asm_arch_headers", ":kconfig_headers"],
)

uboot_asm_offsets(
    name = "gen_asm_offsets",
    src = select({
        ":arch_arm": "arch/arm/lib/asm-offsets.c",
        ":arch_riscv": "arch/riscv/lib/asm-offsets.c",
        ":arch_x86": "arch/x86/lib/asm-offsets.c",
        "//conditions:default": "lib/asm-offsets.c",
    }),
    out = "include/generated/asm-offsets.h",
    hdrs = _ASM_OFFSETS_HDRS + [
        "include/generated/generic-asm-offsets.h",
    ],
    copts = _ASM_OFFSETS_COPTS,
    includes = [
        ".",
        "include",
    ] + select({
        ":arch_arm": ["arch/arm/include"],
        ":arch_sandbox": ["arch/sandbox/include"],
        ":arch_x86": ["arch/x86/include"],
        ":arch_riscv": ["arch/riscv/include"],
        ":arch_mips": ["arch/mips/include"],
        ":arch_powerpc": ["arch/powerpc/include"],
        "//conditions:default": [],
    }),
    deps = [":asm_arch_headers", ":kconfig_headers"],
)

cc_library(
    name = "generated_headers_base",
    hdrs = glob(["include/**/*.h"]) + glob(["arch/*/include/**/*.h"]) + glob(["scripts/dtc/libfdt/**/*.h"]) + glob(["dts/upstream/include/**/*.h"]) + glob([
        "board/**/*.h",
        "boot/**/*.h",
        "cmd/**/*.h",
        "common/**/*.h",
        "disk/**/*.h",
        "drivers/**/*.h",
        "fs/**/*.h",
        "lib/**/*.h",
        "net/**/*.h",
        "test/**/*.h",
    ], exclude = ["lib/mbedtls/**/*.h"]) + _GENERATED_HDRS + select({
        "@u-boot_kconfig//settings:kconfig.CONFIG_MBEDTLS_LIB_Y": glob([
            "lib/mbedtls/*.h",
            "lib/mbedtls/port/*.h",
            "lib/mbedtls/external/mbedtls/include/**/*.h",
            "lib/mbedtls/external/mbedtls/library/**/*.h",
        ]),
        "//conditions:default": [],
    }),
    includes = [
        ".",
        "include",
        "dts/upstream/include",
    ],
    deps = ["@u-boot_kconfig//:config"],
)

cc_library(
    name = "generated_headers",
    hdrs = [
        "include/generated/asm-offsets.h",
        "include/generated/generic-asm-offsets.h",
    ],
    deps = [":generated_headers_base"],
)

