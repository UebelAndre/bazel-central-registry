# --- ARM mach-* directories ---
# Each machine directory is gated on its CONFIG_ARCH_* flag.
# These provide SoC-specific initialization, clock, and board support code.

[
    uboot_cc_library(
        name = "mach_" + mach + "_lib",
        srcs = select({
            ":mach_" + mach: glob(
                [
                    "arch/arm/mach-" + mach + "/**/*.c",
                    "arch/arm/mach-" + mach + "/**/*.S",
                ],
                allow_empty = True,
                exclude = ["arch/arm/mach-" + mach + "/**/*_test*.c"],
            ),
            "//conditions:default": [],
        }),
        includes = select({
            ":mach_" + mach: ["arch/arm/mach-" + mach + "/include"],
            "//conditions:default": [],
        }),
        textual_hdrs = select({
            ":mach_" + mach: glob(
                ["arch/arm/mach-" + mach + "/**/*.h"],
                allow_empty = True,
            ),
            "//conditions:default": [],
        }),
    )
    for mach in [v for v in _ARM_MACHINES.values()]
]

# --- asm/arch include path ---
# U-Boot code uses #include <asm/arch/header.h>. The native build creates
# a symlink: arch/arm/include/asm/arch -> arch-$(SOC) or mach-$(SOC)/include/mach.
# In Bazel we replicate this by generating a directory of copies.
# Machines with mach-*/include/mach/ use that; others use arch/arm/include/asm/arch-*.

# --- asm/arch header remapping ---
# U-Boot code uses #include <asm/arch/foo.h>. The native build creates
# a symlink from asm/arch to either mach-$(SOC)/include/mach/ or
# arch/arm/include/asm/arch-$(SOC)/. We replicate this with
# strip_include_prefix + include_prefix on per-SOC cc_library targets.

# Machines with mach-*/include/mach/ headers
_MACH_INCLUDE_MACHINES = [
    "at91",
    "bcm283x",
    "bcmstb",
    "davinci",
    "exynos",
    "ipq40xx",
    "k3",
    "keystone",
    "kirkwood",
    "mvebu",
    "nexell",
    "orion5x",
    "renesas",
    "s5pc1xx",
    "snapdragon",
    "socfpga",
    "stm32mp",
    "versal",
    "versal2",
    "versal-net",
    "zynq",
    "zynqmp",
    "zynqmp-r5",
]

[
    cc_library(
        name = "asm_arch_mach_" + mach,
        hdrs = glob(
            ["arch/arm/mach-" + mach + "/include/mach/*.h"],
            allow_empty = True,
        ),
        include_prefix = "asm/arch",
        strip_include_prefix = "arch/arm/mach-" + mach + "/include/mach",
    )
    for mach in _MACH_INCLUDE_MACHINES
]

