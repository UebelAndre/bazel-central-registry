]

config_setting(
    name = "CONFIG_CC_OPTIMIZE_FOR_SIZE",
    flag_values = {"@u-boot_kconfig//:CONFIG_CC_OPTIMIZE_FOR_SIZE": "true"},
)

config_setting(
    name = "CONFIG_CC_OPTIMIZE_FOR_SPEED",
    flag_values = {"@u-boot_kconfig//:CONFIG_CC_OPTIMIZE_FOR_SPEED": "true"},
