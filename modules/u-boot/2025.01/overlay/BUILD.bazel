# --- Board code ---
# The native build compiles only board/$(VENDOR)/$(BOARD)/. Since
# CONFIG_SYS_VENDOR is a string flag with ~200 possible values, we
# cannot enumerate all of them in select(). Instead, board code is
# included via glob and the linker resolves only the symbols actually
# referenced. For sandbox, we scope precisely to avoid conflicts.
# For embedded boards, the kconfig transition from with_kconfig_overrides
# ensures only one board's symbols are referenced.

uboot_cc_library(
    name = "board_all",
    srcs = select({
        ":arch_sandbox": glob(["board/sandbox/*.c"]),
        "//conditions:default": glob(
            ["board/**/*.c"],
            allow_empty = True,
        ),
    }),
    textual_hdrs = glob(
        ["board/**/*.h"],
        allow_empty = True,
    ),
)

# --- drivers/ddr/ ---

uboot_cc_library(
    name = "drivers_ddr_fsl",
    srcs =
        kconfig_select(
            "CONFIG_SYS_FSL_DDR3",
            [
                "drivers/ddr/fsl/main.c",
                "drivers/ddr/fsl/util.c",
                "drivers/ddr/fsl/ctrl_regs.c",
                "drivers/ddr/fsl/options.c",
                "drivers/ddr/fsl/lc_common_dimm_params.c",
            ],
        ) +
        kconfig_select(
            "CONFIG_SYS_FSL_DDR4",
            [
                "drivers/ddr/fsl/main.c",
                "drivers/ddr/fsl/util.c",
                "drivers/ddr/fsl/ctrl_regs.c",
                "drivers/ddr/fsl/options.c",
                "drivers/ddr/fsl/lc_common_dimm_params.c",
            ],
        ) +
        kconfig_select(
            "CONFIG_SYS_FSL_MMDC",
            ["drivers/ddr/fsl/fsl_mmdc.c"],
        ),
)

# SoC-specific DDR drivers — stubbed out, compile only for their respective boards.
[
    uboot_cc_library(name = "drivers_ddr_" + v)
    for v in ["imx", "altera", "marvell"]
]

uboot_cc_library(
    name = "drivers_ddr_microchip",
)

# --- drivers/crypto/ ---

uboot_cc_library(
    name = "drivers_crypto",
    srcs =
        kconfig_select(
            "CONFIG_EXYNOS_ACE_SHA",
            ["drivers/crypto/ace_sha.c"],
        ),
    textual_hdrs = glob(["drivers/crypto/*.h"]),
)

uboot_cc_library(
    name = "drivers_crypto_hash",
    srcs =
        kconfig_select(
            "CONFIG_DM_HASH",
            ["drivers/crypto/hash/hash-uclass.c"],
        ) +
        kconfig_select(
            "CONFIG_HASH_SOFTWARE",
            ["drivers/crypto/hash/hash_sw.c"],
        ),
)

uboot_cc_library(
    name = "drivers_crypto_rsa_mod_exp",
    srcs = glob(["drivers/crypto/rsa_mod_exp/*.c"]),
)

uboot_cc_library(
    name = "drivers_crypto_fsl",
)

uboot_cc_library(
    name = "drivers_crypto_aspeed",
)

uboot_cc_library(
    name = "drivers_crypto_nuvoton",
    srcs = glob(["drivers/crypto/nuvoton/*.c"]),
)

# --- net/lwip/ ---

uboot_cc_library(
    name = "net_lwip",
    srcs = kconfig_select(
        "CONFIG_NET_LWIP",
        glob(["net/lwip/*.c"]),
    ),
)

# --- Linker script preprocessing ---

preprocess_linker_script(
    name = "preprocess_lds",
    src = select({
        ":arch_arc": "arch/arc/cpu/u-boot.lds",
        ":arch_arm": "arch/arm/cpu/u-boot.lds",
        ":arch_m68k": "arch/m68k/cpu/u-boot.lds",
        ":arch_microblaze": "arch/microblaze/cpu/u-boot.lds",
        ":arch_mips": "arch/mips/cpu/u-boot.lds",
        ":arch_nios2": "arch/nios2/cpu/u-boot.lds",
        ":arch_powerpc": "arch/powerpc/cpu/mpc83xx/u-boot.lds",
        ":arch_riscv": "arch/riscv/cpu/u-boot.lds",
        ":arch_sandbox": "arch/sandbox/cpu/u-boot.lds",
        ":arch_sh": "arch/sh/cpu/u-boot.lds",
        ":arch_x86": "arch/x86/cpu/u-boot.lds",
        ":arch_xtensa": "arch/xtensa/cpu/u-boot.lds",
    }),
    out = "u-boot.lds.preprocessed",
    hdrs = glob(["include/**/*.h"]) + glob([
        "arch/*/include/**/*.h",
    ]) + [
        "include/config.h",
        ":autoconf_h",
    ],
    copts = [
        "-include",
        "include/linux/kconfig.h",
    ],
    deps = [
        ":asm_arch_headers",
        ":generated_headers_base",
        ":kconfig_headers",
    ],
    includes = [
        "include",
        "arch/arm/include",
        "arch/sandbox/include",
        "arch/x86/include",
        "arch/riscv/include",
        "arch/mips/include",
        "arch/powerpc/include",
    ],
)

# --- Binary post-processing ---

objcopy_binary(
    name = "u-boot-bin",
    src = ":u-boot",
    out = "u-boot.bin",
    tags = ["manual"],
    visibility = ["//visibility:public"],
)

