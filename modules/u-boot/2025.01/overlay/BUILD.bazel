"""Native Bazel build for U-Boot.

Supports all board configurations via rules_kconfig. Consumers select
a board by creating kconfig.overrides in their MODULE.bazel pointing
to any defconfig file from configs/.
"""

load("@bazel_skylib//rules:copy_file.bzl", "copy_file")
load("@bazel_skylib//rules:write_file.bzl", "write_file")
load("@bison//:bison.bzl", "bison")
load("@flex//:flex.bzl", "flex")
load("@rules_cc//cc:cc_binary.bzl", "cc_binary")
load("@rules_cc//cc:cc_library.bzl", "cc_library")
load("@rules_cc//cc:cc_test.bzl", "cc_test")
load("//bazel:asm_offsets.bzl", "uboot_asm_offsets")
load("//bazel:binary_rules.bzl", "embed_binary_data", "generate_config_h", "generate_dt_h", "generate_timestamp_h", "objcopy_binary", "preprocess_linker_script")
load("//bazel:defs.bzl", "UBOOT_VERSION", "kconfig_select", "uboot_cc_library", "uboot_copts", "uboot_defines", "uboot_includes")

exports_files(
    ["Kconfig"] + glob(["configs/*_defconfig"]),
    visibility = ["//visibility:public"],
)

# ======================================================================
# Architecture config_settings
# ======================================================================

[
    config_setting(
        name = "arch_" + arch,
        flag_values = {"@u-boot_kconfig//:CONFIG_SYS_ARCH": arch},
    )
    for arch in [
        "arc",
        "arm",
        "m68k",
        "microblaze",
        "mips",
        "nios2",
        "powerpc",
        "riscv",
        "sandbox",
        "sh",
        "x86",
        "xtensa",
    ]
]

# ARM CPU variant config_settings (from CONFIG_SYS_CPU)
[
    config_setting(
        name = "cpu_" + cpu,
        flag_values = {"@u-boot_kconfig//:CONFIG_SYS_CPU": cpu},
    )
    for cpu in [
        "arm720t",
        "arm920t",
        "arm926ejs",
        "arm1136",
        "arm1176",
        "armv7",
        "armv7m",
        "armv8",
